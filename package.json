{
  "name": "artifacts-ci",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "check": "vp fmt && vp run -r lint && vp run -r test && vp run -r build",
    "dev": "pnpm --parallel --filter docker-proxy --filter ci --filter git dev",
    "lint": "vp run -r lint",
    "prepare": "vp config",
    "smoke": "./scripts/smoke-test.sh $1",
    "test": "vp run -r test"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.2"
}
