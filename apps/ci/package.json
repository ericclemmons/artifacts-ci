{
  "name": "ci",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "dev": "sh -c 'socket=\"$(pwd)/../proxy/.wrangler/docker-privileged.sock\"; wait-for-socket \"$socket\" && DOCKER_HOST=\"unix://$socket\" wrangler dev --port 8787 --inspector-port 9231'",
    "lint": "vp lint"
  },
  "dependencies": {
    "@cloudflare/sandbox": "catalog:",
    "agents": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "portless": "^0.11.1",
    "typescript": "~6.0.2",
    "wait-for-socket": "workspace:*",
    "wrangler": "^4.86.0"
  }
}
