{
  "name": "ci",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --config wrangler.local-actions.jsonc --port 8787 --inspector-port 9231",
    "dev:act": "wrangler dev --config wrangler.act.jsonc --port 8787 --inspector-port 9231",
    "dev:agent-ci": "wrangler dev --config wrangler.agent-ci.jsonc --port 8787 --inspector-port 9231",
    "dev:local-actions": "wrangler dev --config wrangler.local-actions.jsonc --port 8787 --inspector-port 9231",
    "lint": "vp lint",
    "predev": "copy-certs-to-wrangler",
    "predev:act": "copy-certs-to-wrangler",
    "predev:agent-ci": "copy-certs-to-wrangler",
    "predev:local-actions": "copy-certs-to-wrangler"
  },
  "dependencies": {
    "@cloudflare/sandbox": "catalog:",
    "agents": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "copy-certs-to-wrangler": "workspace:*",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
