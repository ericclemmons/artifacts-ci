{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "git-push-cf-git",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-28",
  "observability": {
    "enabled": true,
  },
  "workflows": [
    {
      "name": "git-push-cf-deploy",
      "binding": "DEPLOY_WORKFLOW",
      "class_name": "DeployWorkflow",
    },
  ],
}
